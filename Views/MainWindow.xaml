<Window x:Class="Cardex.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Cardex.ViewModels"
        Title="Cardex — Pokémon TCG Collection Companion"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <!-- Converter bool -> visibilité -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Template carte -->
        <DataTemplate x:Key="CardTemplate" DataType="{x:Type vm:CardViewModel}">
            <Border Width="170" Margin="6" CornerRadius="8"
                    Background="{StaticResource BrushPanel}"
                    BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsWanted}" Value="True">
                                <Setter Property="BorderBrush" Value="#ffd700"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsOwned}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrushHighlight}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <StackPanel>
                        <!-- Image carte -->
                        <Grid Height="230" Background="#111122">
                            <!-- Placeholder chargement -->
                            <TextBlock Text="…" Foreground="{StaticResource BrushSubtext}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="24"
                                       Visibility="{Binding IsLoadingImage, Converter={StaticResource BoolToVis}}"/>
                            <Image Source="{Binding CardImage}" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>

                        <!-- Infos -->
                        <Grid Margin="6,4,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="24"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource BrushText}"
                                           FontSize="11" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Name}"/>
                                <TextBlock Foreground="{StaticResource BrushSubtext}" FontSize="10">
                                    <Run Text="N°"/><Run Text="{Binding Number, Mode=OneWay}"/>
                                    <Run Text="·"/>
                                    <Run Text="{Binding Rarity, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Checkbox Owned + compteur d'exemplaires -->
                                <CheckBox Margin="0,4,0,0"
                                          IsChecked="{Binding IsOwned}"
                                          Foreground="{StaticResource BrushText}"
                                          FontSize="11"
                                          Content="Owned"
                                          Cursor="Hand"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOwned}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Button Command="{Binding DecrementCommand}"
                                            Style="{StaticResource SetButtonStyle}"
                                            Width="22" Height="22" FontSize="14" Padding="0"
                                            Content="−"/>
                                    <Border Width="30" Background="#111122" CornerRadius="3" Margin="3,0">
                                        <TextBlock Text="{Binding Quantity}"
                                                   Foreground="{StaticResource BrushHighlight}"
                                                   FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Button Command="{Binding IncrementCommand}"
                                            Style="{StaticResource SetButtonStyle}"
                                            Width="22" Height="22" FontSize="14" Padding="0"
                                            Content="+"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Étoile Wants -->
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding IsWanted}"
                                          Style="{StaticResource StarButtonStyle}"
                                          FontSize="18"
                                          VerticalAlignment="Top"
                                          Margin="2,2,0,0"
                                          ToolTip="Mark as wanted"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template set dans la sidebar -->
        <DataTemplate x:Key="SetItemTemplate" DataType="{x:Type vm:SetViewModel}">
            <Button Style="{StaticResource SetButtonStyle}"
                    Command="{Binding DataContext.SelectSetCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    HorizontalAlignment="Stretch">
                <Border BorderThickness="1" CornerRadius="3">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="BorderBrush" Value="#ffd700"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushHighlight}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="4,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Étoile favori -->
                        <ToggleButton Grid.Column="0"
                                      IsChecked="{Binding IsFavorite}"
                                      Command="{Binding DataContext.ToggleFavoriteCommand,
                                                RelativeSource={RelativeSource AncestorType=Window}}"
                                      CommandParameter="{Binding}"
                                      Style="{StaticResource StarButtonStyle}"
                                      FontSize="13"
                                      VerticalAlignment="Center"/>
                        <!-- Symbole du set -->
                        <Image Grid.Column="1"
                               Source="{Binding SymbolImage}"
                               Width="16" Height="16"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Name}"
                                   Foreground="{StaticResource BrushText}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                        <!-- Complétion ou badge Completed -->
                        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="6,0,0,0">
                            <TextBlock Text="{Binding CompletionText}"
                                       Foreground="{StaticResource BrushSubtext}"
                                       FontSize="10">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="✓ Completed !"
                                       Foreground="#ffd700"
                                       FontSize="10" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>

        <!-- Template tuile favoris (écran d'accueil) -->
        <DataTemplate x:Key="HomeFavoriteTileTemplate" DataType="{x:Type vm:SetViewModel}">
            <Button Style="{StaticResource SetButtonStyle}"
                    Command="{Binding DataContext.SelectSetCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Margin="4">
                <Border Width="120" CornerRadius="6" BorderThickness="2" Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                    <Setter Property="BorderBrush" Value="#ffd700"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource BrushHighlight}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid Height="48" Background="#111122">
                            <Image Source="{Binding SymbolImage}" Width="32" Height="32"
                                   Stretch="Uniform" HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>
                        <StackPanel Margin="6,4,6,6">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource BrushText}"
                                       FontSize="10" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"/>
                            <TextBlock Foreground="{StaticResource BrushSubtext}" FontSize="9">
                                <Run Text="{Binding CompletionText, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="✓ Completed!"
                                       Foreground="#ffd700"
                                       FontSize="9" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsComplete}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Button>
        </DataTemplate>

        <!-- Template résultat de recherche globale -->
        <DataTemplate x:Key="SearchResultTemplate" DataType="{x:Type vm:SearchResultViewModel}">
            <Button Style="{StaticResource SetButtonStyle}"
                    Command="{Binding DataContext.OpenSearchResultCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}">
                <Border Width="140" Margin="6" CornerRadius="8"
                        Background="{StaticResource BrushPanel}"
                        BorderThickness="2">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="{StaticResource BrushHighlight}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OwnedQuantity}" Value="0">
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid Height="185" Background="#111122">
                            <TextBlock Text="…" Foreground="{StaticResource BrushSubtext}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="24"
                                       Visibility="{Binding IsLoadingImage, Converter={StaticResource BoolToVis}}"/>
                            <Image Source="{Binding CardImage}" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <Border CornerRadius="4" Background="{StaticResource BrushHighlight}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,4,4,0" Padding="4,2">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OwnedQuantity}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding OwnedQuantity}"
                                           Foreground="{StaticResource BrushBg}"
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </Grid>
                        <StackPanel Margin="6,4,6,6">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource BrushText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"/>
                            <TextBlock Text="{Binding SetName}"
                                       Foreground="{StaticResource BrushHighlight}"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Foreground="{StaticResource BrushSubtext}" FontSize="10">
                                <Run Text="N°"/><Run Text="{Binding Number, Mode=OneWay}"/>
                                <Run Text=" · "/><Run Text="{Binding Rarity, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource BrushPanel}"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- En-tête sidebar -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BrushAccent}"
                        Padding="12,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="{Binding AppLogo}" Width="36" Height="36" Margin="0,0,4,0"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center"/>
                            <Image Source="{Binding AppName}"
                                   Height="36" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                Command="{Binding GoHomeCommand}"
                                ToolTip="Home"
                                FontSize="18" Padding="6,2"
                                Style="{StaticResource SetButtonStyle}">
                            ⌂
                        </Button>
                    </Grid>
                </Border>

                <!-- Liste des séries / sets -->
                <ScrollViewer DockPanel.Dock="Bottom"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Series}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SeriesViewModel}">
                                <Expander IsExpanded="{Binding IsExpanded}"
                                          Style="{StaticResource SeriesExpanderStyle}"
                                          Margin="4,2">
                                    <Expander.Header>
                                        <TextBlock Text="{Binding SeriesName}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Margin="2,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource BrushHighlight}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavoriteGroup}" Value="True">
                                                            <Setter Property="Foreground" Value="#ffd700"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Sets}"
                                                  ItemTemplate="{StaticResource SetItemTemplate}"
                                                  Margin="8,0,0,0"/>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== ZONE PRINCIPALE ===== -->
        <Grid Grid.Row="0" Grid.Column="1">

            <!-- Écran d'accueil -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeVisible}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barre de recherche globale -->
                <Border Grid.Row="0" Background="{StaticResource BrushAccent}" Padding="20,14">
                    <Grid>
                        <TextBox Text="{Binding GlobalSearch, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#111122"
                                 Foreground="{StaticResource BrushText}"
                                 CaretBrush="{StaticResource BrushText}"
                                 BorderBrush="{StaticResource BrushAccent}"
                                 BorderThickness="1"
                                 Padding="10,7"
                                 FontSize="13">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="Search all cards across all sets…"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="13" IsHitTestVisible="False"
                                   Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding GlobalSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Sets favoris -->
                <Border Grid.Row="1"
                        Background="{StaticResource BrushPanel}"
                        BorderBrush="{StaticResource BrushAccent}" BorderThickness="0,0,0,1"
                        Padding="12,10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HomeFavorites.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="★  Favorite Sets"
                                   Foreground="#ffd700"
                                   FontSize="12" FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding HomeFavorites}"
                                      ItemTemplate="{StaticResource HomeFavoriteTileTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Résultats de recherche globale -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource BrushBg}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GlobalSearch}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding SearchResults}"
                                  ItemTemplate="{StaticResource SearchResultTemplate}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" Margin="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Message de bienvenue -->
                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GlobalSearch}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Select a set from the sidebar"
                               Foreground="{StaticResource BrushSubtext}" FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="or search for cards across all sets above"
                               Foreground="{StaticResource BrushSubtext}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Vue set -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHomeVisible}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

            <!-- En-tête set sélectionné -->
            <Border Grid.Row="0" MinHeight="90" ClipToBounds="True">
                <Grid>
                    <!-- Fond de base -->
                    <Border Background="{StaticResource BrushAccent}"/>

                    <!-- Logo du set en filigrane au centre -->
                    <Image Source="{Binding SelectedSet.LogoImage}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           MaxHeight="80"
                           Opacity="0.35"
                           Margin="0,8"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Dégradé des deux côtés pour lisibilité du texte -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0f3460" Offset="0.0"/>
                                <GradientStop Color="#AA0f3460" Offset="0.2"/>
                                <GradientStop Color="#000f3460" Offset="0.5"/>
                                <GradientStop Color="#AA0f3460" Offset="0.8"/>
                                <GradientStop Color="#FF0f3460" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Contenu -->
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nom du set + boutons filtres -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedSet.Name}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource BrushText}"
                                       Visibility="{Binding SelectedSet, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding SelectedSet.Series}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushSubtext}"
                                       Visibility="{Binding SelectedSet, Converter={StaticResource BoolToVis}}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <ToggleButton IsChecked="{Binding SelectedSet.ShowWantsOnly}"
                                              FontSize="12" Margin="0,0,8,0">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSet.IsLoading}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                    ★ Show all wants
                                </ToggleButton>
                                <ToggleButton IsChecked="{Binding SelectedSet.ShowDupesOnly}"
                                              FontSize="12">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSet.IsLoading}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                    Show dupes only
                                </ToggleButton>
                            </StackPanel>
                        </StackPanel>

                        <!-- Droite : bouton + compteur -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <!-- Check / Uncheck all -->
                            <Button Content="{Binding SelectedSet.ToggleAllLabel}"
                                    Command="{Binding ToggleAllOwnedCommand}"
                                    FontSize="12" Padding="12,6"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SetButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSet.IsLoading}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedSet.CompletionText}"
                                           Foreground="{StaticResource BrushHighlight}"
                                           FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="cards owned"
                                           Foreground="{StaticResource BrushSubtext}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Barre de filtres -->
            <Border Grid.Row="1"
                    Background="{StaticResource BrushPanel}"
                    BorderBrush="{StaticResource BrushAccent}"
                    BorderThickness="0,0,0,1"
                    Padding="10,6">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SelectedSet.IsLoading}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <!-- Champ texte libre avec placeholder -->
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding SelectedSet.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#111122"
                                 Foreground="{StaticResource BrushText}"
                                 CaretBrush="{StaticResource BrushText}"
                                 BorderBrush="{StaticResource BrushAccent}"
                                 BorderThickness="1"
                                 Padding="8,5"
                                 FontSize="12">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="4"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="Search by name or number…"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="12" IsHitTestVisible="False"
                                   Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedSet.SearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Sélecteur de rareté -->
                    <ComboBox Grid.Column="1"
                              Style="{StaticResource DarkComboBoxStyle}"
                              ItemsSource="{Binding SelectedSet.AvailableRarities}"
                              SelectedItem="{Binding SelectedSet.SelectedRarity}"
                              FontSize="12"
                              Margin="8,0,0,0"/>
                </Grid>
            </Border>

            <!-- Indicateur chargement -->
            <StackPanel Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedSet.IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading cards…"
                           Foreground="{StaticResource BrushSubtext}"
                           FontSize="16"/>
            </StackPanel>

            <!-- Grille de cartes -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BrushBg}"
                          x:Name="CardsScrollViewer"
                          ScrollChanged="CardsScrollViewer_ScrollChanged">
                <ItemsControl ItemsSource="{Binding SelectedSet.FilteredCards}"
                              ItemTemplate="{StaticResource CardTemplate}"
                              x:Name="CardsItemsControl"
                              Loaded="CardsItemsControl_Loaded">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
            </Grid><!-- fin Vue set -->
        </Grid>

        <!-- ===== BARRE DE STATUT ===== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource BrushAccent}"
                Padding="10,0">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource BrushSubtext}"
                           FontSize="11"
                           VerticalAlignment="Center"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding RefreshSetsCommand}"
                        ToolTip="Refresh from API (clears cache)"
                        FontSize="13" Padding="6,2"
                        Style="{StaticResource SetButtonStyle}">
                    ↻ Refresh
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
