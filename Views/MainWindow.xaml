<Window x:Class="Cardex.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Cardex.ViewModels"
        Title="Cardex — Pokémon TCG Collection"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBg}">

    <Window.Resources>
        <!-- Converter bool -> visibilité -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Template carte -->
        <DataTemplate x:Key="CardTemplate" DataType="{x:Type vm:CardViewModel}">
            <Border Width="170" Margin="6" CornerRadius="8"
                    Background="{StaticResource BrushPanel}"
                    BorderThickness="2">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOwned}" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource BrushHighlight}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <StackPanel>
                        <!-- Image carte -->
                        <Grid Height="230" Background="#111122">
                            <!-- Placeholder chargement -->
                            <TextBlock Text="…" Foreground="{StaticResource BrushSubtext}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="24"
                                       Visibility="{Binding IsLoadingImage, Converter={StaticResource BoolToVis}}"/>
                            <Image Source="{Binding CardImage}" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Grid>

                        <!-- Infos -->
                        <StackPanel Margin="6,4,6,6">
                            <TextBlock Text="{Binding Name}"
                                       Foreground="{StaticResource BrushText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Name}"/>
                            <TextBlock Foreground="{StaticResource BrushSubtext}" FontSize="10">
                                <Run Text="N°"/><Run Text="{Binding Number, Mode=OneWay}"/>
                                <Run Text="·"/>
                                <Run Text="{Binding Rarity, Mode=OneWay}"/>
                            </TextBlock>

                            <!-- Checkbox possédée -->
                            <CheckBox Margin="0,4,0,0"
                                      IsChecked="{Binding IsOwned}"
                                      Foreground="{StaticResource BrushText}"
                                      FontSize="11"
                                      Content="Owned"
                                      Cursor="Hand"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Template set dans la sidebar -->
        <DataTemplate x:Key="SetItemTemplate" DataType="{x:Type vm:SetViewModel}">
            <Button Style="{StaticResource SetButtonStyle}"
                    Command="{Binding DataContext.SelectSetCommand,
                              RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    HorizontalAlignment="Stretch">
                <Border>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource BrushHighlight}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="4,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- Symbole du set -->
                        <Image Grid.Column="0"
                               Source="{Binding SymbolImage}"
                               Width="16" Height="16"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Name}"
                                   Foreground="{StaticResource BrushText}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding CompletionText}"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="10"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== SIDEBAR ===== -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{StaticResource BrushPanel}"
                BorderBrush="{StaticResource BrushAccent}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- En-tête sidebar -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BrushAccent}"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="CARDEX"
                                   Foreground="{StaticResource BrushHighlight}"
                                   FontSize="16" FontWeight="Black"/>
                        <TextBlock Text="Pokémon TCG Collection"
                                   Foreground="{StaticResource BrushSubtext}"
                                   FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Liste des séries / sets -->
                <ScrollViewer DockPanel.Dock="Bottom"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Series}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:SeriesViewModel}">
                                <Expander IsExpanded="{Binding IsExpanded}"
                                          Style="{StaticResource SeriesExpanderStyle}"
                                          Margin="4,2">
                                    <Expander.Header>
                                        <TextBlock Text="{Binding SeriesName}"
                                                   Foreground="{StaticResource BrushHighlight}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Margin="2,0"/>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Sets}"
                                                  ItemTemplate="{StaticResource SetItemTemplate}"
                                                  Margin="8,0,0,0"/>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== ZONE PRINCIPALE ===== -->
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- En-tête set sélectionné -->
            <Border Grid.Row="0" MinHeight="90" ClipToBounds="True">
                <Grid>
                    <!-- Fond de base -->
                    <Border Background="{StaticResource BrushAccent}"/>

                    <!-- Logo du set en filigrane à droite -->
                    <Image Source="{Binding SelectedSet.LogoImage}"
                           Stretch="Uniform"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           MaxHeight="80"
                           Opacity="0.35"
                           Margin="0,8,16,8"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- Dégradé pour lisibilité du texte à gauche -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF0f3460" Offset="0.0"/>
                                <GradientStop Color="#EE0f3460" Offset="0.45"/>
                                <GradientStop Color="#880f3460" Offset="0.75"/>
                                <GradientStop Color="#000f3460" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Contenu -->
                    <Grid Margin="16,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nom du set (ou message accueil) -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource BrushText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Select a set from the sidebar"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSet}" Value="{x:Null}">
                                                <Setter Property="Text" Value="Select a set from the sidebar"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding SelectedSet.Name}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource BrushText}"
                                       Visibility="{Binding SelectedSet, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding SelectedSet.Series}"
                                       FontSize="11"
                                       Foreground="{StaticResource BrushSubtext}"
                                       Visibility="{Binding SelectedSet, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Droite : bouton + compteur -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="{Binding SelectedSet.ToggleAllLabel}"
                                    Command="{Binding ToggleAllOwnedCommand}"
                                    FontSize="12" Padding="12,6"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SetButtonStyle}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSet.IsLoading}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedSet.CompletionText}"
                                           Foreground="{StaticResource BrushHighlight}"
                                           FontSize="22" FontWeight="Bold"/>
                                <TextBlock Text="cards owned"
                                           Foreground="{StaticResource BrushSubtext}"
                                           FontSize="10" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Indicateur chargement -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding SelectedSet.IsLoading, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Loading cards…"
                           Foreground="{StaticResource BrushSubtext}"
                           FontSize="16"/>
            </StackPanel>

            <!-- Grille de cartes -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="{StaticResource BrushBg}"
                          x:Name="CardsScrollViewer"
                          ScrollChanged="CardsScrollViewer_ScrollChanged">
                <ItemsControl ItemsSource="{Binding SelectedSet.Cards}"
                              ItemTemplate="{StaticResource CardTemplate}"
                              x:Name="CardsItemsControl"
                              Loaded="CardsItemsControl_Loaded">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ===== BARRE DE STATUT ===== -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="{StaticResource BrushAccent}"
                Padding="10,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource BrushSubtext}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
